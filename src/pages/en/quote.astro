---
import Layout from '../../layouts/Layout.astro';
---

<Layout>
  <main>

    <!-- HERO -->
    <section>
      <h1>Textile Printing Services in Armenia (Yerevan)</h1>

      <p>
        We provide professional textile printing services for businesses and individuals:
        DTF printing, silk screen printing, custom T-shirts, and textile bag printing.
      </p>

      <div style="margin-top: 16px;">
        <a href="/en/quote">Request a Quote</a>
        <span> | </span>
        <a href="/en/portfolio">View Portfolio</a>
      </div>
    </section>

    <hr />

    <!-- DTF -->
    <section>
      <h2>DTF Printing</h2>
      <p>
        High-quality full-color printing for custom garments. Ideal for small and medium runs,
        complex designs, and photo-quality prints.
      </p>
      <ul>
        <li>Works on cotton and blended fabrics</li>
        <li>Suitable for detailed designs</li>
        <li>Durable and flexible print</li>
      </ul>
    </section>

    <hr />

    <!-- SILK SCREEN -->
    <section>
      <h2>Silk Screen Printing</h2>
      <p>
        Cost-effective solution for bulk orders. Best for uniforms, corporate apparel,
        and promotional clothing.
      </p>
      <ul>
        <li>Low cost per unit for large orders</li>
        <li>Very durable printing method</li>
        <li>Ideal for simple logo designs</li>
      </ul>
    </section>

    <hr />

    <!-- T-SHIRTS -->
    <section>
      <h2>Custom T-Shirt Printing</h2>
      <p>
        We print custom T-shirts for individuals, teams, and businesses.
        Perfect for gifts, branding, and events.
      </p>
      <ul>
        <li>Personal designs</li>
        <li>Business branding</li>
        <li>Team uniforms</li>
      </ul>
    </section>

    <hr />

    <!-- BAGS -->
    <section>
      <h2>Textile Bag Printing</h2>
      <p>
        Eco-friendly printed bags for shops, cafes, and corporate promotions.
      </p>
      <ul>
        <li>Canvas tote bags</li>
        <li>Retail branding bags</li>
        <li>Event promotional bags</li>
      </ul>
    </section>

    <hr />

    <!-- CTA -->
    <section>
      <h2>Need Printing Services?</h2>

      <p>
        Send us your design, quantity, and product type. We will calculate price and production time.
      </p>

      <a href="/en/quote">Get a Quote</a>
    </section>

  </main>
</Layout>